<?xml version="1.0" encoding="UTF-8"?>
<settings>
    <servers>
        <server>
            <id>maven-releases</id>
            <username>${env.MAVEN_REPO_USER}</username>
            <password>${env.MAVEN_REPO_PASSWORD}</password>
        </server>
    </servers>

    <profiles>
        <profile>
            <id>nexus</id>
            <repositories>
                <!-- Для Spring Boot и публичных зависимостей -->
                <repository>
                    <id>central</id>
                    <url>${env.MAVEN_REPO_URL}/repository/maven-public/</url>
                    <releases><enabled>true</enabled></releases>
                    <snapshots><enabled>false</enabled></snapshots>
                </repository>
                <!-- Для наших артефактов (core) -->
                <repository>
                    <id>maven-releases</id>
                    <url>${env.MAVEN_REPO_URL}/repository/maven-releases/</url>
                    <releases><enabled>true</enabled></releases>
                    <snapshots><enabled>false</enabled></snapshots>
                </repository>
            </repositories>
        </profile>
    </profiles>

    <activeProfiles>
        <activeProfile>nexus</activeProfile>
    </activeProfiles>
</settings>